{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m1-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m1-medium",
        "simulator": true
      },
      "android": {
        "buildType": "apk",
        "autoIncrement": true,
        "credentialsSource": "local",
        "gradle": {
          "buildType": "release",
          "minSdkVersion": 24,
          "compileSdkVersion": 34,
          "targetSdkVersion": 34,
          "buildToolsVersion": "34.0.0"
        },
        "image": "latest"
      }
    },
    "standalone-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "autoIncrement": true,
        "credentialsSource": "local"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m1-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true,
        "credentialsSource": "local",
        "gradle": {
          "buildType": "release",
          "minSdkVersion": 24,
          "compileSdkVersion": 34,
          "targetSdkVersion": 34,
          "buildToolsVersion": "34.0.0"
        },
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {}
  }
}